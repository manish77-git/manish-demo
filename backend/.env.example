# Server
PORT=3000
NODE_ENV=development

# Firebase
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Google Cloud Vision API
GOOGLE_VISION_API_KEY=your-google-vision-api-key

# AI Model
AI_MODEL_MODE=vision  # 'vision' for Google Vision API, 'tensorflow' for TF.js, 'both' for composite
TF_MODEL_PATH=./models/quickdraw

# Game Config
DEFAULT_DRAWING_TIME=60
MAX_PLAYERS_PER_GAME=6
